# 项目配置示例文件
# 使用方法：
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 编辑 .env 文件，填入实际的 API key 和配置
#   3. 或者直接设置环境变量: export QWEN_API_KEY=your-api-key
#
# 配置优先级（从高到低）：
#   1. 系统环境变量
#   2. 此 .env 文件中的变量
#   3. 代码中的默认值

# ==================== 基础应用配置 ====================
APP_NAME="Related Work Workflow Agent"
APP_ENV="development"
APP_DEBUG="false"
LOG_LEVEL="INFO"

# ==================== Qwen API 配置 ====================
# 必须配置：从阿里云百炼控制台获取 API key
# 获取地址: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=""

# 可选配置：API 基础地址（一般无需修改）
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 可选配置：使用的模型名称
# 可选值: qwen-plus, qwen-max, qwen-turbo 等
QWEN_MODEL="qwen-plus"
